@article{luizfelipe,
 abstract={Esse projeto de pesquisa propõe o desenvolvimento de uma página web que integre um modelo de processamento de linguagem natural ao sistema de monitoramento Zabbix, tornando as métricas e alertas técnicos de infraestrutura mais acessíveis a usuários não especializados. Ao coletar dados em tempo real sobre disponibilidade, desempenho e segurança de redes, servidores e aplicações acadêmicas, o sistema utilizará técnicas de sumarização para geração de relatórios simplificados, livres de jargões técnicos. Esses relatórios serão exibidos em uma interface web, isolada do front-end do Zabbix, com recursos adicionais de acessibilidade, de forma que gestores e pessoas com deficiência visual ou motora compreendam e interajam eficientemente com as informações geradas. O desenvolvimento deste projeto contribuirá com a tomada de decisão institucional e assegurará a continuidade dos serviços relacionados ao ensino, pesquisa e extensão do IFG com maior simplificação, democratização das informações e economia de recursos.},
 author={Luiz Felipe de Castro Santana},
 title={Interface web simplificada e com acessibilidade para compreensão dos dados monitorados pelo Zabbix},
 year = {2025},
 journal = {Programa Institucional de Bolsas de Iniciação em Desenvolvimento Tecnológico e Inovação - Edital nº 22},
 abbr={PIBIT},
 preview={luiz.png},
}

@article{caue,
 abstract={As ferramentas digitais como realidade virtual, realidade aumentada, aplicativos para dispositivos móveis e efeitos visuais interativos têm revolucionado a forma como o público vivencia apresentações musicais ao vivo. Eventos culturais incorporam iluminação, projeções e ambientes envolventes que intensificam a conexão sensorial com os shows. Embora estas inovações estejam se tornando mais comuns no setor do entretenimento, ainda são pouco exploradas na literatura acadêmica. Esse projeto de pesquisa propõe realizar uma revisão sistemática da literatura sobre a aplicação de tecnologias digitais na mediação da experiência musical ao vivo. A metodologia exploratória e de mapeamento permitirá avaliar a importância científica do tema, entender as metodologias empregadas e identificar quais aspectos são mais frequentemente abordados. Adicionalmente, a pesquisa pretende identificar lacunas e tendências, fornecendo informações valiosas para investigações futuras. Ao final, espera-se apresentar uma visão abrangente do estado da arte das interações entre tecnologia e música ao vivo, contribuindo para o avanço em performances artísticas e estudos culturais.},
 author={Caue Rafael Evangelista de Jesus},
 title={Investigação da experiência musical ao vivo mediada por tecnologias digitais: uma revisão sistemática da literatura},
 year = {2025},
 journal = {Programa Institucional de Bolsas de Iniciação Científica - Edital nº 21},
 abbr= {PIBIC},
 preview={caue.png},
}