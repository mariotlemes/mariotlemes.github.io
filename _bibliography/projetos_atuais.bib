@article{chatbot2025-2,
abstract={Este projeto de pesquisa aborda a concepção e construção de um sistema de conversação (chatbot) contextualizado para elucidar dúvidas específicas da comunidade acadêmica do Instituto Federal de Goiás Campus Formosa. A integração do sistema de perguntas e repostas a um modelo de linguagem largo (LLM – Language Large Model), aliado ao emprego de técnicas de indexação de documentos específicos e inerentes ao ensino, pesquisa e extensão, proporcionam respostas eficientes não somente às questões da comunidade interna, professores/as, técnicos/as administrativos/as, alunos/as, mas também da comunidade externa, a respeito de diferentes atividades executadas pelo Instituto. A pesquisa enfatiza o emprego da tecnologia de Inteligência Artificial como fator chave no suporte acadêmico e divulgação de informações presentes em documentos oficiais produzidos por diferentes setores da Instituição.},
abbr={Pesquisa},
author={Letícia Vieira and Giulia Martins and Mario Lemes},
journal={Instituto Federal de Goiás - Campus Formosa},
title={Sistema de Conversação Automatizado e Especializado para o Contexto do IFG Campus Formosa},
year={2025-2},
}

@article{IseminarioPesquisa2025,
abstract={O presente projeto propõe a realização do I Seminário de Pesquisas de Trabalhos de Conclusão de Curso (TCC) do curso de Tecnologia em Análise e Desenvolvimento de Sistemas (TADS). O evento busca consolidar um espaço de socialização e divulgação das pesquisas desenvolvidas pelos estudantes concluintes, promovendo integração entre discentes, docentes e comunidade externa. Além de fortalecer a formação acadêmica, o seminário pretende contribuir para a valorização da pesquisa aplicada, inovação tecnológica e extensão universitária no contexto local e regional.},
abbr={Extensão},
author={Milene Galvão (coordenador) and Mario Lemes},
journal={Instituto Federal de Goiás - Campus Formosa},
title={I Seminário de Pesquisas de TCC do Curso TADS},
year={2025-2},
}








